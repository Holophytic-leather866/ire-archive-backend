# IRE Resources Semantic Search - Environment Configuration Example
# Copy this file to .env for local development

# =============================================================================
# QDRANT CONFIGURATION
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=nonprofit_knowledge
VECTOR_SIZE=384

# =============================================================================
# REDIS CONFIGURATION (for SSO session storage)
# =============================================================================
# Local development: Use Docker Redis (started via 'make dev-start')
REDIS_URL=redis://localhost:6379

# Production (Fly.io): Use Fly Redis or Upstash
# REDIS_URL=redis://default:YOUR_PASSWORD@your-redis-host.fly.dev:6379

# =============================================================================
# MEMBERSUITE SSO CONFIGURATION
# =============================================================================
# Obtain these credentials from IRE admin
# MS_TENANT_ID=12345
# MS_ASSOCIATION_ID=your-association-guid

# Session configuration
# SESSION_SECRET=generate-a-random-32-character-secret-here
# SESSION_TTL_SECONDS=3600
# SESSION_COOKIE_NAME=ire_session

# URLs
# FRONTEND_URL=http://localhost:5173
# MS_REQUIRE_MEMBERSHIP=true

# =============================================================================
# API CONFIGURATION
# =============================================================================
PORT=8000
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# CORS — Additional allowed origins for community frontend deployments.
# Use this when running a frontend on a domain other than archive.ire.org
# (e.g., when deploying ireapps/ire-archive-frontend to your own Vercel project).
# Accepts a JSON array (preferred) or a comma-separated list.
# ADDITIONAL_ALLOWED_ORIGINS='["https://your-frontend.example.com"]'
# ADDITIONAL_ALLOWED_ORIGINS=https://your-frontend.example.com,https://staging.example.com

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
MODEL_NAME=all-MiniLM-L6-v2
MODEL_CACHE_DIR=./models_cache

# =============================================================================
# RATE LIMITING
# =============================================================================
